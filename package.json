{
  "name": "@getflute/sdk",
  "version": "0.2.0",
  "description": "Official server-side TypeScript/Node.js SDK for the Flute payment platform.",
  "keywords": [
    "flute",
    "getflute",
    "payments",
    "sdk",
    "typescript",
    "nodejs",
    "rest",
    "api",
    "oauth"
  ],
  "homepage": "https://github.com/getflute/flute-sdk-typescript#readme",
  "bugs": {
    "url": "https://github.com/getflute/flute-sdk-typescript/issues"
  },
  "license": "MIT",
  "author": "Flute",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getflute/flute-sdk-typescript.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist coverage .tsup *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "release": "changeset publish",
    "version-packages": "changeset version",
    "openapi:types": "openapi-typescript ./openapi/isv-api-v2.json -o ./src/types/generated/isv-api-v2.d.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "msw": "^2.14.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "sideEffects": false
}
